{
  "name": "obsidian-sidecard",
  "version": "0.1.3",
  "description": "SideCard adds a sidebar card library for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "obsidian:load": "node scripts/load-obsidian.mjs",
    "obsidian:reload": "obsidian reload && obsidian plugin:reload id=sidecard && obsidian command id=sidecard:open-card-library"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin"
  ],
  "author": "shuuul",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.24",
    "@types/sortablejs": "^1.15.9",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "obsidian": "^1.8.7",
    "ts-jest": "^29.4.11",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "sortablejs": "^1.15.7"
  }
}
